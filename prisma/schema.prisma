generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  name           String
  password       String?
  googleId       String?      @unique
  provider       AuthProvider @default(EMAIL)
  avatarUrl      String?
  registrationId String?
  phone          String?
  role           Role         @default(USER)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  cases            Case[]
  documents        Document[]
  drafts           Draft[]
  chatSessions     ChatSession[]
  caseChatSessions CaseChatSession[]

  @@map("users")
}

model Case {
  id          String     @id @default(cuid())
  title       String
  clientName  String?
  referenceNo String?
  description String?
  status      CaseStatus @default(OPEN)
  dueDate     DateTime?  @db.Timestamptz(6)
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?  @db.Timestamptz(6)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  documents    Document[]
  drafts       Draft[]
  chatSessions CaseChatSession[]

  @@index([userId], map: "idx_cases_userid")
  @@map("cases")
}

model Draft {
  id        String        @id @default(cuid())
  title     String
  category  DraftCategory @default(GENERAL)
  content   String?
  status    DraftStatus   @default(DRAFT)
  score     Float?
  deletedAt DateTime?     @db.Timestamptz(6)
  createdAt DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  userId    String
  caseId    String?
  case      Case?         @relation(fields: [caseId], references: [id], onUpdate: NoAction)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([caseId], map: "idx_drafts_caseid")
  @@index([userId], map: "idx_drafts_userid")
  @@map("drafts")
}

model Document {
  id          String   @id @default(cuid())
  filename    String
  mimeType    String
  sizeBytes   Int
  storagePath String
  s3Bucket    String?
  s3Key       String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  userId      String
  caseId      String?
  case        Case?    @relation(fields: [caseId], references: [id], onUpdate: NoAction)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  chatSessions ChatSession[]

  @@index([caseId], map: "idx_documents_caseid")
  @@index([userId], map: "idx_documents_userid")
  @@map("documents")
}

model ChatSession {
  id         String        @id @default(cuid())
  userId     String
  documentId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@unique([userId, documentId])
  @@index([userId])
  @@index([documentId])
  @@map("chat_sessions")
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  role       MessageRole
  content    String
  isAnalysis Boolean     @default(false)
  createdAt  DateTime    @default(now())
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_messages")
}

model CaseChatSession {
  id        String            @id @default(cuid())
  userId    String
  caseId    String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  case      Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  messages  CaseChatMessage[]

  @@unique([userId, caseId])
  @@index([userId])
  @@index([caseId])
  @@map("case_chat_sessions")
}

model CaseChatMessage {
  id         String          @id @default(cuid())
  sessionId  String
  role       MessageRole
  content    String
  isAnalysis Boolean         @default(false)
  createdAt  DateTime        @default(now())
  session    CaseChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("case_chat_messages")
}

model LawEntry {
  id          String   @id @default(cuid())
  category    String
  section     String?
  title       String
  description String
  tags        String[] @default([])
  sourceUrl   String?
  court       String?
  year        Int?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([category], map: "idx_law_entries_category")
  @@map("law_entries")
}

model LangchainPgEmbedding {
  id           String                 @id @unique(map: "ix_langchain_pg_embedding_id") @db.VarChar
  collectionId String?                @map("collection_id") @db.Uuid
  embedding    Unsupported("vector")?
  document     String?                @db.VarChar
  cmetadata    Json?
  collection   LangchainPgCollection? @relation(fields: [collectionId], references: [uuid], onDelete: Cascade, onUpdate: NoAction)

  @@index([cmetadata(ops: JsonbPathOps)], map: "ix_cmetadata_gin", type: Gin)
  @@map("langchain_pg_embedding")
}

model LangchainPgCollection {
  uuid       String                 @id @db.Uuid
  name       String                 @unique @db.VarChar
  cmetadata  Json?                  @db.Json
  embeddings LangchainPgEmbedding[]

  @@map("langchain_pg_collection")
}

model DocumentCache {
  documentId      String   @id @map("document_id")
  s3_key          String?
  extractedText   String   @map("extracted_text")
  draft_reply     String
  citations       Json     @default("[]")
  is_grounded     Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  analysis_result Json?

  @@map("document_cache")
}

enum MessageRole {
  user
  assistant
  system
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum Role {
  USER
  ADMIN
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  REVIEW
  COMPLETED
  ARCHIVED
}

enum DraftCategory {
  SCN_REPLY
  APPEAL_MEMORANDUM
  LEGAL_OPINION
  GENERAL
}

enum DraftStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  EXPORTED
}
