// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ───
model User {
  id              String       @id @default(cuid())
  email           String       @unique
  name            String
  password        String?      // bcrypt hash (null for Google-only users)
  googleId        String?      @unique
  provider        AuthProvider @default(EMAIL)
  avatarUrl       String?
  registrationId  String?      // CA Registration ID
  phone           String?
  role            Role         @default(USER)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  cases    Case[]
  drafts   Draft[]
  documents Document[]
  chatSessions ChatSession[]

  @@map("users")
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum Role {
  USER
  ADMIN
}

// ─── Case ───
model Case {
  id          String     @id @default(cuid())
  title       String
  clientName  String?
  referenceNo String?
  description String?
  status      CaseStatus @default(OPEN)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  drafts    Draft[]
  documents Document[]

  @@index([userId])
  @@map("cases")
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  REVIEW
  COMPLETED
  ARCHIVED
}

// ─── Draft ───
model Draft {
  id        String      @id @default(cuid())
  title     String
  category  DraftCategory @default(GENERAL)
  content   String?     @db.Text
  status    DraftStatus @default(DRAFT)
  score     Float?      // AI quality score
  deletedAt DateTime?   // Soft delete timestamp
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  caseId    String?
  case      Case?  @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([caseId])
  @@map("drafts")
}

enum DraftCategory {
  SCN_REPLY
  APPEAL_MEMORANDUM
  LEGAL_OPINION
  GENERAL
}

enum DraftStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  EXPORTED
}

// ─── Document ───
model Document {
  id          String   @id @default(cuid())
  filename    String
  mimeType    String
  sizeBytes   Int
  storagePath String   // S3 URL or local path
  s3Bucket    String?  // S3 bucket name (for analysis uploads)
  s3Key       String?  // S3 object key (for analysis uploads)
  createdAt   DateTime @default(now())

  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  caseId    String?
  case      Case?  @relation(fields: [caseId], references: [id], onDelete: SetNull)

  chatSessions ChatSession[]

  @@index([userId])
  @@index([caseId])
  @@map("documents")
}

// ─── Chat Session (per user, per document) ───
model ChatSession {
  id         String        @id @default(cuid())
  userId     String
  documentId String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  messages   ChatMessage[]

  @@unique([userId, documentId])
  @@index([userId])
  @@index([documentId])
  @@map("chat_sessions")
}

// ─── Chat Message ───
model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       MessageRole
  content    String      @db.Text
  isAnalysis Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}

enum MessageRole {
  user
  assistant
  system
}

// ─── Law Library Entry ───
model LawEntry {
  id          String   @id @default(cuid())
  category    String   // GST Law, Case Law, Income Tax, Notification
  section     String?  // Section 29(2)(c), Madras HC 2022, etc.
  title       String
  description String   @db.Text
  tags        String[] // PostgreSQL array
  sourceUrl   String?
  court       String?
  year        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("law_entries")
}

// ─── AI Services Internal Tables (Do Not Drop) ───

// Created by LangChain Postgres
model LangchainPgEmbedding {
  uuid       String  @id
  collectionId String  @map("collection_id")
  embedding  String? // Assuming vector type is not natively supported without extensions, treat as String or ignore in Prisma operations if unsupported
  document   String?
  cmetadata  Json?
  customId   String? @map("custom_id")

  collection LangchainPgCollection @relation(fields: [collectionId], references: [uuid], onDelete: Cascade)

  @@map("langchain_pg_embedding")
}

model LangchainPgCollection {
  name      String
  cmetadata Json?
  uuid      String  @id

  embeddings LangchainPgEmbedding[]

  @@map("langchain_pg_collection")
}

// Created by internal Python DB Service
model DocumentCache {
  id               BigInt   @id @default(autoincrement())
  documentId       String   @unique @map("document_id") // doc_abc123
  extractedText    String   @map("extracted_text")      @db.Text
  analysisSummary  String?  @map("analysis_summary")    @db.Text
  sectionsApplied  String?  @map("sections_applied")    @db.Text
  demands          String?  @db.Text
  deadlines        String?  @db.Text
  immediateActions String?  @map("immediate_actions")   @db.Text
  citations        Json?    // list of strings
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("document_cache")
}

model ChatMessage {
  id         BigInt   @id @default(autoincrement())
  sessionId  String   @map("session_id") // UUID from frontend
  role       String   // 'user' | 'assistant'
  mode       String   // 'analyze' | 'chat' | 'strategy' | 'draft'
  content    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}
